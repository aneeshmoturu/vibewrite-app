generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -------------------------------------------------
// PHASE 1.5: The User Table (For Credits)
// -------------------------------------------------
model User {
  id        String   @id @default(uuid())
  userId    String   @unique
  credits   Int      @default(5)
}

// -------------------------------------------------
// PHASE 2: The History Database Table
// -------------------------------------------------
model Generation {
  id        String   @id @default(uuid())
  userId    String   
  prompt    String   
  content   String   
  createdAt DateTime @default(now())
}